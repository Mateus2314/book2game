# ============================================
# Book2Game - Test Environment Configuration
# ============================================
# IMPORTANTE: Este arquivo é usado apenas durante os testes
# Usa hostnames do Docker em vez de localhost

# Database Configuration for Testing
DATABASE_URL=postgresql://book2game:book2game_dev@postgres:5432/book2game_db
TEST_DATABASE_URL=postgresql://book2game_test:book2game_test@postgres-test:5432/book2game_test_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Cache Configuration
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=86400

# Application Settings
ENVIRONMENT=testing
DEBUG=True
LOG_LEVEL=DEBUG

# Security & Authentication
SECRET_KEY=test-secret-key-for-testing-only-min-32-chars-length-required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERAL=60/minute

# CORS Settings
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=True

# External APIs - Google Books
GOOGLE_BOOKS_API_KEY=AIzaSyDOKZlsFPK0tftBqNb0yveC4lWMcjnAkPo
GOOGLE_BOOKS_BASE_URL=https://www.googleapis.com/books/v1

# Hugging Face
HUGGINGFACE_API_KEY=hf_test_key_for_testing
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models
MODEL_NAME=facebook/bart-large-mnli
AI_REQUEST_TIMEOUT=30
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_BACKOFF_FACTOR=2

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=test-password
SMTP_FROM_EMAIL=noreply@book2game.com

# Logging
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
LOG_FORMAT=json

# RAWG API
RAWG_API_KEY=test-rawg-key
RAWG_BASE_URL=https://api.rawg.io/api

TESTING=true
